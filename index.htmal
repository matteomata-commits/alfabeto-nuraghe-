<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>DEMOCODEX</title>
</head>

<body style="background-color:#F4F0E6 !important; font-family:serif; text-align:center; margin-top:30px;">

<h2>DEMOCODEX</h2>

<p style="color:#555; font-size:14px;">1. scegli una runa &nbsp; → &nbsp; 2. tocca il vano dove vuoi inserirla</p>

<!-- COMPLESSO: 5 VANI -->
<svg width="340" height="340" viewBox="0 0 680 420" xmlns="http://www.w3.org/2000/svg" style="touch-action:manipulation;">
<style>
.slotstone{fill:#EDE8DC;stroke:#3D3A33;stroke-width:1.4;cursor:pointer;}
.slotstone.filled{fill:#E4DCC8;}
.slotlabel{font-family:serif;font-size:13px;fill:#3D3A33;}
.slotglyph{fill:none;stroke:#1C1A16;stroke-width:5;stroke-linecap:square;}
.slotglyph.empty{opacity:0.15;}
.conn{stroke:#3D3A33;stroke-width:1;opacity:0.5;fill:none;}
</style>

<line class="conn" x1="190" y1="210" x2="300" y2="120"/>
<line class="conn" x1="300" y1="120" x2="340" y2="200"/>
<line class="conn" x1="440" y1="100" x2="340" y2="200"/>
<line class="conn" x1="430" y1="260" x2="340" y2="200"/>
<line class="conn" x1="190" y1="210" x2="340" y2="200"/>

<g class="slot" id="slot-A" data-letter="A" onclick="posiziona('A')">
  <circle class="slotstone" cx="340" cy="200" r="70"/>
  <text class="slotlabel" x="340" y="148" text-anchor="middle">A</text>
  <g id="glyph-A" class="slotglyph empty" transform="translate(340,200)"></g>
</g>

<g class="slot" id="slot-B" data-letter="B" onclick="posiziona('B')">
  <circle class="slotstone" cx="190" cy="210" r="52"/>
  <text class="slotlabel" x="190" y="168" text-anchor="middle">B</text>
  <g id="glyph-B" class="slotglyph empty" transform="translate(190,210)"></g>
</g>

<g class="slot" id="slot-C" data-letter="C" onclick="posiziona('C')">
  <circle class="slotstone" cx="300" cy="100" r="42"/>
  <text class="slotlabel" x="300" y="66" text-anchor="middle">C</text>
  <g id="glyph-C" class="slotglyph empty" transform="translate(300,100)"></g>
</g>

<g class="slot" id="slot-D" data-letter="D" onclick="posiziona('D')">
  <circle class="slotstone" cx="440" cy="100" r="48"/>
  <text class="slotlabel" x="440" y="62" text-anchor="middle">D</text>
  <g id="glyph-D" class="slotglyph empty" transform="translate(440,100)"></g>
</g>

<g class="slot" id="slot-E" data-letter="E" onclick="posiziona('E')">
  <circle class="slotstone" cx="430" cy="260" r="40"/>
  <text class="slotlabel" x="430" y="228" text-anchor="middle">E</text>
  <g id="glyph-E" class="slotglyph empty" transform="translate(430,260)"></g>
</g>

</svg>

<br>

<!-- SELETTORE RUNE -->
<svg width="300" height="300" viewBox="0 0 680 680" xmlns="http://www.w3.org/2000/svg" style="touch-action:manipulation; margin-top:10px;">
<style>
.stone{fill:#EDE8DC;stroke:#3D3A33;stroke-width:1.4;}
.rune{fill:none;stroke:#1C1A16;stroke-width:6;stroke-linecap:square;stroke-linejoin:miter;}
.dot{fill:#1C1A16;}
.ringline{fill:none;stroke:#3D3A33;stroke-width:1;opacity:0.5;}
.runebtn{cursor:pointer;}
.runebtn:hover .rune{stroke:#9c3a1d;}
.runebtn:hover .dot{fill:#9c3a1d;}
.runebtn.selected .rune{stroke:#1d7a5c;}
.runebtn.selected .dot{fill:#1d7a5c;}
</style>

<circle cx="340" cy="340" r="300" fill="#F4F0E6"/>

<path class="stone" d="M340,50
c14,-2 22,10 36,8 c16,-2 20,16 34,18 c18,2 24,18 36,28 c14,12 10,30 18,42 c10,16 26,18 30,36 c4,18 -8,30 -6,46 c2,18 18,28 14,46 c-4,18 -22,18 -28,34 c-6,16 6,32 -4,46 c-10,14 -28,8 -42,16 c-14,8 -16,26 -32,30 c-16,4 -28,-10 -44,-10 c-16,0 -28,14 -44,10 c-16,-4 -18,-22 -32,-30 c-14,-8 -32,-2 -42,-16 c-10,-14 2,-30 -4,-46 c-6,-16 -24,-16 -28,-34 c-4,-18 12,-28 14,-46 c2,-18 -8,-20 2,-36 c8,-12 24,-14 34,-26 c12,-14 8,-32 22,-44 c12,-10 16,-28 32,-32 c14,-4 18,-14 30,-16 Z" />

<circle class="ringline" cx="340" cy="340" r="252"/>

<g class="dot">
<circle cx="340" cy="92" r="4"/><circle cx="478" cy="130" r="4"/><circle cx="568" cy="240" r="4"/>
<circle cx="588" cy="380" r="4"/><circle cx="528" cy="500" r="4"/><circle cx="408" cy="572" r="4"/>
<circle cx="272" cy="572" r="4"/><circle cx="152" cy="500" r="4"/><circle cx="92" cy="380" r="4"/>
<circle cx="112" cy="240" r="4"/><circle cx="202" cy="130" r="4"/>
</g>

<g class="runebtn" id="pick-A" onclick="seleziona('A')" transform="translate(340,156)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent"/>
<path class="rune" d="M-16,-26 L16,-26 L16,-6 L-16,-6 L-16,14 L16,14 M-16,14 L-16,26"/>
<circle class="dot" cx="0" cy="-16" r="3.5"/><circle class="dot" cx="0" cy="4" r="3.5"/>
</g>

<g class="runebtn" id="pick-B" onclick="seleziona('B')" transform="translate(456,210) rotate(60)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent" transform="rotate(-60)"/>
<path class="rune" d="M-18,-24 L0,-24 L0,0 L18,0 L18,24 M-18,24 L-18,0 L0,0"/>
<circle class="dot" cx="-9" cy="-12" r="3.5"/><circle class="dot" cx="9" cy="12" r="3.5"/>
</g>

<g class="runebtn" id="pick-C" onclick="seleziona('C')" transform="translate(524,340) rotate(90)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent" transform="rotate(-90)"/>
<path class="rune" d="M-18,-24 L-18,24 M-18,-24 L18,-24 M-18,0 L14,0 M-18,24 L18,24"/>
<circle class="dot" cx="6" cy="-24" r="3.5"/><circle class="dot" cx="2" cy="0" r="3.5"/>
</g>

<g class="runebtn" id="pick-D" onclick="seleziona('D')" transform="translate(456,470) rotate(120)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent" transform="rotate(-120)"/>
<path class="rune" d="M-18,-24 L18,-24 L18,0 L-18,0 L-18,24 L18,24"/>
<circle class="dot" cx="0" cy="-12" r="3.5"/><circle class="dot" cx="0" cy="12" r="3.5"/>
</g>

<g class="runebtn" id="pick-E" onclick="seleziona('E')" transform="translate(340,524) rotate(180)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent" transform="rotate(-180)"/>
<path class="rune" d="M-16,-26 L16,-26 L16,-6 L-16,-6 L-16,14 L16,14 M-16,14 L-16,26"/>
<circle class="dot" cx="0" cy="-16" r="3.5"/><circle class="dot" cx="0" cy="4" r="3.5"/>
</g>

<g class="runebtn" id="pick-F" onclick="seleziona('F')" transform="translate(224,470) rotate(240)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent" transform="rotate(-240)"/>
<path class="rune" d="M-18,-24 L0,-24 L0,0 L18,0 L18,24 M-18,24 L-18,0 L0,0"/>
<circle class="dot" cx="-9" cy="-12" r="3.5"/><circle class="dot" cx="9" cy="12" r="3.5"/>
</g>

<g class="runebtn" id="pick-G" onclick="seleziona('G')" transform="translate(156,340) rotate(270)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent" transform="rotate(-270)"/>
<path class="rune" d="M-18,-24 L-18,24 M-18,-24 L18,-24 M-18,0 L14,0 M-18,24 L18,24"/>
<circle class="dot" cx="6" cy="-24" r="3.5"/><circle class="dot" cx="2" cy="0" r="3.5"/>
</g>

<g class="runebtn" id="pick-H" onclick="seleziona('H')" transform="translate(224,210) rotate(300)">
<rect x="-30" y="-40" width="60" height="80" fill="transparent" transform="rotate(-300)"/>
<path class="rune" d="M-18,-24 L18,-24 L18,0 L-18,0 L-18,24 L18,24"/>
<circle class="dot" cx="0" cy="-12" r="3.5"/><circle class="dot" cx="0" cy="12" r="3.5"/>
</g>

<circle cx="340" cy="340" r="118" fill="#E4DCC8" stroke="#3D3A33" stroke-width="1.4"/>
<circle cx="340" cy="340" r="92" fill="none" stroke="#3D3A33" stroke-width="0.6" opacity="0.5"/>

<g class="runebtn" id="pick-I" onclick="seleziona('I')">
<rect x="250" y="290" width="180" height="100" fill="transparent"/>
<g transform="translate(280,340)">
<path class="rune" d="M0,-46 L0,46 M0,-46 L24,-46 L24,-22 L0,-22 M0,8 L24,8 L24,32 L0,32"/>
<circle class="dot" cx="12" cy="-34" r="4"/><circle class="dot" cx="12" cy="20" r="4"/>
</g>
<g transform="translate(360,340)">
<path class="rune" d="M-22,-46 L22,-46 L22,-2 L-22,-2 L-22,46 L22,46"/>
<circle class="dot" cx="0" cy="-24" r="4"/><circle class="dot" cx="0" cy="22" r="4"/>
</g>
</g>

</svg>

<br>

<button onclick="invia()" style="margin-top:14px; padding:8px 18px;">INVIA</button>
<button onclick="reset()" style="padding:8px 18px;">RESET</button>

<p id="codice" style="font-family:monospace; font-size:16px;"></p>

<div id="output"></div>

<script>

const glyphPaths = {
  A: "M-16,-26 L16,-26 L16,-6 L-16,-6 L-16,14 L16,14 M-16,14 L-16,26",
  B: "M-18,-24 L0,-24 L0,0 L18,0 L18,24 M-18,24 L-18,0 L0,0",
  C: "M-18,-24 L-18,24 M-18,-24 L18,-24 M-18,0 L14,0 M-18,24 L18,24",
  D: "M-18,-24 L18,-24 L18,0 L-18,0 L-18,24 L18,24",
  E: "M-16,-26 L16,-26 L16,-6 L-16,-6 L-16,14 L16,14 M-16,14 L-16,26",
  F: "M-18,-24 L0,-24 L0,0 L18,0 L18,24 M-18,24 L-18,0 L0,0",
  G: "M-18,-24 L-18,24 M-18,-24 L18,-24 M-18,0 L14,0 M-18,24 L18,24",
  H: "M-18,-24 L18,-24 L18,0 L-18,0 L-18,24 L18,24",
  I: "M-22,-30 L0,-30 L0,30 L22,30"
};

let runaSelezionata = null;
let codiceVani = { A:"", B:"", C:"", D:"", E:"" };

function seleziona(lettera) {
  document.querySelectorAll(".runebtn").forEach(function(el) { el.classList.remove("selected"); });
  const el = document.getElementById("pick-" + lettera);
  if (el) el.classList.add("selected");
  runaSelezionata = lettera;
}

function posiziona(vano) {
  if (!runaSelezionata) {
    alert("Prima scegli una runa dal cerchio qui sotto");
    return;
  }
  codiceVani[vano] = runaSelezionata;

  const g = document.getElementById("glyph-" + vano);
  g.innerHTML = "<path d='" + glyphPaths[runaSelezionata] + "'/>";
  g.classList.remove("empty");

  document.querySelector("#slot-" + vano + " .slotstone").classList.add("filled");

  document.querySelectorAll(".runebtn").forEach(function(el) { el.classList.remove("selected"); });
  runaSelezionata = null;
}

const poesie = {

  "HADFC": {
    titolo: "Goccia di storia",
    testo: "c'è una goccia di sangue o di rugiada\nche sdrucciola tra i solchi della storia\nche rende viva la carne dell'uomo\nc'è una goccia di sangue o di rugiada\nche scorre tra gli incavi della fronte\ndi gente in gente per generazioni\nsulla tacita pelle dei mortali\nai primi raggi del sole essa appare\ne rifulge di morte e primavera"
  },

  "BIEGA": {
    titolo: "Bandiere di pace",
    testo: "più bandiere di pace sulla terra\nbasta soldati morti per la guerra\n\npiù aquiloni in volo più colombe\nbasta a chi soffoca il cielo di bombe\n\npiù fratelli nel mondo più alleati\ninondiamo di fiori i carri armati\n\npiù libri per bambini e per bambine\nbasta fucili bombe a mano e mine\n\nche il vento scuota le nostre bandiere\nbasta bunker trincee e frontiere"
  },

  "FCAHI": {
    titolo: "Luna di cenere",
    testo: "oggi la luna è una perla di cenere\nche si fa polvere tra le mie dita\noggi la luna è una perla di cenere\nche sporca il grano e soffoca il raccolto\n\nsferza nel cielo un tumulto di lame\ngrigie le lacrime austere le nuvole\ntacito ascolto il pianto del bracciante\nche per anni ha mietuto il suo raccolto\n\noggi la luna è una perla di cenere\nche si fa polvere tra le mie dita\noggi la luna è una perla di cenere\nche fa eco alle rovine del passato"
  },

  "GBDEI": {
    titolo: "Poeti erranti",
    testo: "si dovrà dire di noi poeti\nche spettiniamo il sole\nche strucchiamo la luna\nche siamo i pagliacci e i saltimbanchi\ndi una carovana che fa del viaggio\nla sua destinazione"
  },

  "EHCBG": {
    titolo: "Promemoria",
    testo: "passare il tempo\na contare le lentiggini\nbianche della notte"
  },

  "DIAFB": {
    titolo: "Parentesi sospese",
    testo: "ci sono parentesi che non si chiudono\nche restano sospese tra le righe\naperte tra le pagine della vita\nparole lasciate a metà\ncome pianti interrotti\ncome promesse tradite"
  },

  "CGEHA": {
    titolo: "Beatrice",
    testo: "fa attenzione bella bionda\nil mondo è pieno di chimere\nte ne vai a notte fonda\na tirare su il sedere\ntra chi sniffa bianche stelle\ntra chi passa il tempo a bere\nfa attenzione Beatrice\nquesto mondo è pien di lupi\ndell'italia i frutti acerbi\nsono in terra già caduti\nmuratori, avvocati,\nprofessori conosciuti\ndemagoghi, pesciaroli,\nsia temuti che venduti\nfa attenzione Beatrice\ni pilastri del decoro son caduti"
  }

};

function invia() {
  const codiceInterno = codiceVani.A + codiceVani.B + codiceVani.C + codiceVani.D + codiceVani.E;

  document.getElementById("codice").innerText = "Codice: " + codiceInterno;

  const poesia = poesie[codiceInterno];
  const output = document.getElementById("output");

  if (poesia) {
    output.innerHTML =
      "<h3>" + poesia.titolo + "</h3>" +
      "<pre style='white-space:pre-wrap; font-size:18px;'>" +
      poesia.testo +
      "</pre>";
  } else {
    output.innerHTML = "❌ nessuna poesia per questo codice";
  }
}

function reset() {
  codiceVani = { A:"", B:"", C:"", D:"", E:"" };
  runaSelezionata = null;
  ["A","B","C","D","E"].forEach(function(v) {
    const g = document.getElementById("glyph-" + v);
    g.innerHTML = "";
    g.classList.add("empty");
    document.querySelector("#slot-" + v + " .slotstone").classList.remove("filled");
  });
  document.querySelectorAll(".runebtn").forEach(function(el) { el.classList.remove("selected"); });
